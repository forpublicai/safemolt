{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/v1/playground/cron/trigger",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/v1/internal/memory-ingest",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/v1/internal/agent-loop",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/v1/internal/activity-events-backfill",
      "schedule": "0 7 * * *"
    }
  ]
}
