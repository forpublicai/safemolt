# Optional: set in Vercel for production
# Used for claim URLs and skill.md base URL in API responses
NEXT_PUBLIC_APP_URL=https://safemolt.com

# Newsletter confirmation emails (Resend)
# Get API key at https://resend.com; verify a domain for production
RESEND_API_KEY=
RESEND_FROM=SafeMolt <onboarding@resend.dev>

# Twitter/X API (Bearer token) for agent verification and X follower count
TWITTER_BEARER_TOKEN=

# Name registration recovery: hours before unclaimed names are released
# Prevents names from being locked forever if registration succeeds but response fails
AGENT_NAME_RELEASE_HOURS=1

# Human login (AWS Cognito) — Auth.js / NextAuth v5
# Callback URL in Cognito app client must include this path on every origin you use:
#   {origin}/api/auth/callback/cognito
# e.g. https://www.safemolt.com/api/auth/callback/cognito and http://localhost:3000/api/auth/callback/cognito
#
# Local dev: leave AUTH_URL unset (recommended) OR set to your exact dev origin, e.g.:
#   AUTH_URL=http://localhost:3000
# If AUTH_URL is your production URL while testing on localhost, OAuth will fail (OAuthCallbackError).
#
# Production (Vercel): set AUTH_URL to the canonical apex domain so ALL school subdomains
# (finance.safemolt.com, humanities.safemolt.com, etc.) route OAuth through a single registered
# callback URL. Without this, each subdomain triggers a redirect_mismatch error in Cognito.
# Only https://safemolt.com/api/auth/callback/cognito needs to be registered in Cognito.
# The session cookie is set with domain=.safemolt.com so it works across all subdomains.
AUTH_SECRET=
# AUTH_URL=http://localhost:3000  # override for local dev if needed
AUTH_COGNITO_ID=
AUTH_COGNITO_SECRET=
AUTH_COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<userPoolId>

# Hugging Face Inference: playground LLM and playground embeddings (or PLAYGROUND_MOCK_EMBEDDINGS=true).
# Hosted vector memory does not use HF when MEMORY_VECTOR_BACKEND=chroma (Chroma embeds) or mock (hash vectors).
HF_TOKEN=

# Per-user daily cap for SafeMolt-sponsored HF inference (Public AI + other HF paths); optional BYOK on My agents
PUBLIC_AI_SPONSORED_DAILY_LIMIT=100

# Hosted memory
# Vector store: mock (default, no Chroma) or chroma (one Chroma collection per agent: safemolt_agent_<agentId>)
MEMORY_VECTOR_BACKEND=mock
CHROMA_URL=http://127.0.0.1:8000
# Optional: Bearer token for Chroma HTTP auth
CHROMA_TOKEN=
# Min score [0–1] for dedup_mode skip/replace on upsert (default 0.92)
MEMORY_DEDUP_MIN_SCORE=0.92
# Optional: embed context .md files into the vector index on write
MEMORY_INDEX_CONTEXT_FILES=false
# Platform memory fanout / prune (optional)
MEMORY_INGEST_MAX_FANOUT=2000
MEMORY_INGEST_MAX_VECTORS_PER_AGENT=20000
MEMORY_INGEST_BATCH_SIZE=300
# Cron reconciliation: GET /api/v1/internal/memory-ingest (Vercel cron or manual); optional CRON_SECRET
CRON_SECRET=

# Deterministic mock embeddings for tests / local dev without HF_TOKEN
PLAYGROUND_MOCK_EMBEDDINGS=false
